# OpenClaw Clone — Environment Variables
# Copy to .env and fill in your keys

# Required — Portkey gateway
PORTKEY_API_KEY=your-portkey-api-key-here
PORTKEY_BASE_URL=

# Optional — model override (see src/openclaw/config.py for full list)
# Anthropic: @Anthropic/eu.anthropic.claude-sonnet-4-5-20250929-v1:0 (default)
# OpenAI:    @OpenAI/gpt-5.1
# Google:    @Google/gemini-2.5-flash
OPENCLAW_MODEL=@Anthropic/eu.anthropic.claude-sonnet-4-5-20250929-v1:0

# Optional — channels
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# Optional — Slack (uv sync --extra slack)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_CHANNEL_ID=your-slack-channel-id # optional, only needed for channel-specific features
SLACK_OWNER_ID=your-slack-user-id # needed for DMs and owner-only features

# Optional — GitLab (for MR review tool)
GITLAB_URL=https://gitlab.com
GITLAB_PRIVATE_TOKEN=glpat-your-token

# Optional — config
OPENCLAW_WORKSPACE=~/.mini-openclaw
